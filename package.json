{
  "name": "second-brain",
  "version": "0.1.0",
  "description": "Local-first AI-agent-driven desktop app.",
  "main": "dist/main/main.js",
  "author": "Second Brain",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:127.0.0.1:${VITE_PORT:-5173} && npm run build:electron && node scripts/start-electron-dev.cjs\"",
    "build": "npm run typecheck && npm run build:electron && vite build",
    "build:electron": "tsc -b tsconfig.main.json tsconfig.preload.json --force",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json",
    "package:win": "npm run build && electron-builder --win",
    "preview": "vite preview --host 127.0.0.1",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:headless": "SECOND_BRAIN_HEADLESS=1 VITE_PORT=5174 VITE_DEV_SERVER_URL=http://127.0.0.1:5174 xvfb-run -a dbus-run-session -- npm run dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1",
    "zustand": "^5.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "gray-matter": "^4.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
